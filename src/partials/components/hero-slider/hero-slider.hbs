<div class="hero-slider-container">
  {{! Slider List Items }}
  <div class="hero-slider-wrapper swiper-wrapper">
    <div class="hero-slider-item swiper-slide">
      <div class="hero-slider-content">
        <h3 class="hero-slider-subtitle">Precision discipline</h3>
        <h2 class="hero-slider-title">Air Pistol Shooting</h2>
        <p class="hero-slider-description">
          Short-distance shooting focused on control, stability, and perfect
          trigger work.
        </p>
        <a class="hero-slider-button" href="#"><span>Learn More</span></a>
      </div>
    </div>

    <div class="hero-slider-item swiper-slide">
      <div class="hero-slider-content">
        <h3 class="hero-slider-subtitle">Absolute accuracy</h3>
        <h2 class="hero-slider-title">Air Rifle Shooting</h2>
        <p class="hero-slider-description">
          Olympic precision at 10 meters, where every millimeter defines the
          result.
        </p>
        <a class="hero-slider-button" href="#"><span>Learn More</span></a>
      </div>
    </div>

    <div class="hero-slider-item swiper-slide">
      <div class="hero-slider-content">
        <h3 class="hero-slider-subtitle">Speed & reaction</h3>
        <h2 class="hero-slider-title">Skeet Shooting</h2>
        <p class="hero-slider-description">
          Dynamic clay target shooting with fast angles and rapid target
          acquisition.
        </p>
        <a class="hero-slider-button" href="#"><span>Learn More</span></a>
      </div>
    </div>

    <div class="hero-slider-item swiper-slide">
      <div class="hero-slider-content">
        <h3 class="hero-slider-subtitle">Focus & timing</h3>
        <h2 class="hero-slider-title">Trap Shooting</h2>
        <p class="hero-slider-description">
          Unpredictable targets launched at distance demand sharp focus and
          timing.
        </p>
        <a class="hero-slider-button" href="#"><span>Learn More</span></a>
      </div>
    </div>

    <div class="hero-slider-item swiper-slide">
      <div class="hero-slider-content">
        <h3 class="hero-slider-subtitle">Field simulation</h3>
        <h2 class="hero-slider-title">Sporting Shooting</h2>
        <p class="hero-slider-description">
          Realistic shooting scenarios that simulate hunting conditions and
          varied targets.
        </p>
        <a class="hero-slider-button" href="#"><span>Learn More</span></a>
      </div>
    </div>
  </div>

  {{! Slider Pagination }}
  <div class="hero-slider-controls">
    <ul class="hero-slider-pagination">
      <div class="hero-slider-indicator"></div>
      <li class="hero-slider-tab">Air Pistol</li>
      <li class="hero-slider-tab">Air Rifle</li>
      <li class="hero-slider-tab">Skeet Shooting</li>
      <li class="hero-slider-tab">Trap Shooting</li>
      <li class="hero-slider-tab">Sporting Shooting</li>
    </ul>
  </div>

  {{! Slider Navigation (Prev/Next) }}
  <div class="hero-slider-navigation">
    <button type="button" id="hero-slide-prev">
      <svg width="32" height="32" aria-hidden="true">
        <use href="assets/icons/sprite.svg#icon-ui-arrow-left"></use>
      </svg>
    </button>

    <button type="button" id="hero-slide-next">
      <svg width="32" height="32" aria-hidden="true">
        <use href="assets/icons/sprite.svg#icon-ui-arrow-right"></use>
      </svg>
    </button>
  </div>
</div>
