<!-- Disciplines Section -->
<section class="disciplines section">
  <div class="container">
    <!-- Section Header -->
    <header class="section__header">
      <!-- Section Title -->
      <h2 class="section__title">Disciplines</h2>
      <!-- Section Link -->
      <a class="section__link" href="disciplines/">
        <span class="text">Read more</span>
        <span class="u-sr-only">&nbsp;about shooting disciplines</span>
        <svg class="icon" width="16" height="16" aria-hidden="true">
          <use href="assets/icons/sprite.svg#icon-ui-forward-right"></use>
        </svg>
      </a>
    </header>

    <!-- Section Excerpt -->
    <p class="section__excerpt">
      Explore our diverse shooting disciplines and find the perfect training
      path for your skill level and goals.
    </p>

    <!-- Section Body -->
    <div class="section__body">
      <!-- Team Slider (main container) -->
      <div class="disciplines-slider swiper">
        <!-- Slider Wrapper -->
        <div class="disciplines-slider__wrapper">
          <!-- Swiper additional required wrapper -->
          <ul class="swiper-wrapper">
            <!-- Discipline Slide - Pistol -->
            <li class="swiper-slide">
              <article
                class="discipline-card"
                aria-label="Shooting discipline: Pistol"
              >
                <div class="discipline-card__body">
                  {{!-- Discipline Card Title --}}
                  <h3 class="discipline-card__title">Pistol</h3>
                  {{!-- Discipline Card Description --}}
                  <p class="discipline-card__description">
                    Pistol shooting focuses on precision, control, and
                    concentration. This discipline is ideal for developing
                    accuracy and consistency, whether you are training
                    recreationally or preparing for competitions.
                  </p>
                </div>

                <div class="discipline-card__footer">
                  {{!-- Discipline Card Link --}}
                  <a class="discipline-card__link link-btn" href="disciplines/">
                    <span class="text">Learn more</span>
                    <span class="u-sr-only">
                      about pistol shooting disciplines and training
                      opportunities.
                    </span>
                  </a>
                </div>
              </article>
            </li>

            <!-- Discipline Slide - Rifle -->
            <li class="swiper-slide">
              <article
                class="discipline-card"
                aria-label="Shooting discipline: Rifle"
              >
                <div class="discipline-card__body">
                  {{!-- Discipline Card Title --}}
                  <h3 class="discipline-card__title">Rifle</h3>
                  {{!-- Discipline Card Description --}}
                  <p class="discipline-card__description">
                    Rifle shooting emphasizes stability, breathing technique,
                    and long-range accuracy. It is suitable for shooters who
                    want to master technical skills and improve their overall
                    shooting discipline.
                  </p>
                </div>

                <div class="discipline-card__footer">
                  {{!-- Discipline Card Link --}}
                  <a class="discipline-card__link link-btn" href="disciplines/">
                    <span class="text">Learn more</span>
                    <span class="u-sr-only">
                      about rifle shooting disciplines and long-range training.
                    </span>
                  </a>
                </div>
              </article>
            </li>

            <!-- Discipline Slide - Skeet -->
            <li class="swiper-slide">
              <article
                class="discipline-card"
                aria-label="Shooting discipline: Skeet"
              >
                <div class="discipline-card__body">
                  {{!-- Discipline Card Title --}}
                  <h3 class="discipline-card__title">Skeet</h3>
                  {{!-- Discipline Card Description --}}
                  <p class="discipline-card__description">
                    Skeet shooting challenges shooters with fast-moving targets
                    crossing from different directions. This discipline is
                    perfect for developing timing, precision, and smooth
                    shooting techniques.
                  </p>
                </div>

                <div class="discipline-card__footer">
                  {{!-- Discipline Card Link --}}
                  <a class="discipline-card__link link-btn" href="disciplines/">
                    <span class="text">Learn more</span>
                    <span class="u-sr-only">
                      about skeet shooting and moving target practice.
                    </span>
                  </a>
                </div>
              </article>
            </li>

            <!-- Discipline Slide - Trap -->
            <li class="swiper-slide">
              <article
                class="discipline-card"
                aria-label="Shooting discipline: Trap"
              >
                <div class="discipline-card__body">
                  {{!-- Discipline Card Title --}}
                  <h3 class="discipline-card__title">Trap</h3>
                  {{!-- Discipline Card Description --}}
                  <p class="discipline-card__description">
                    Trap shooting is a dynamic shotgun discipline where targets
                    are launched away from the shooter at varying angles. It
                    helps improve reaction time, coordination, and shooting
                    rhythm.
                  </p>
                </div>

                <div class="discipline-card__footer">
                  {{!-- Discipline Card Link --}}
                  <a class="discipline-card__link link-btn" href="disciplines/">
                    <span class="text">Learn more</span>
                    <span class="u-sr-only">
                      about trap shooting and clay target training.
                    </span>
                  </a>
                </div>
              </article>
            </li>
          </ul>

          <!-- Swiper Navigation Buttons -->
          <div class="disciplines-slider__navigation">
            <button class="disciplines-slider__btn-prev swiper-button-prev">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-arrow-left"></use>
              </svg>
            </button>
            <button class="disciplines-slider__btn-next swiper-button-next">
              <svg width="32" height="32" aria-hidden="true">
                <use href="assets/icons/sprite.svg#icon-ui-arrow-right"></use>
              </svg>
            </button>
          </div>

          <!-- Swiper Pagination -->
          <div class="disciplines-slider__pagination swiper-pagination"></div>
        </div>
      </div>
    </div>
  </div>
</section>
