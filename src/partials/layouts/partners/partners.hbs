<!-- Partners Section -->
<section class="partners section">
  <div class="container">
    <!-- Section Header -->
    <header class="section__header">
      <!-- Section Title -->
      <h2 class="section__title">Partners</h2>

      <!-- Section Link -->
      <!-- <a class="section__link" href="partners/">
        <span class="text">See all</span>
