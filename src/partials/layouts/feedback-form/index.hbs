<!-- Contact Us Form -->
<div class='feedback-form {{addClass}}'>
  <h2 class='feedback-form__title'>Feedback form</h2>
  <p class='feedback-form__call-to-action'>Leave your message and we'll contact you back</p>

  <form class='feedback-form__form' autocomplete='off' data-form='feedback'>
    <!-- Name Field -->
    <label class='feedback-form__field feedback-form__field--floating-label'>
      <input class='feedback-form__input' type='text' name='user-name' placeholder=' ' required />
      <span class='feedback-form__label'>Name</span>
      <svg class='feedback-form__icon' width='16px' height='16px'>
        <use href='assets/icons/sprite.svg#icon-ui-person'></use>
      </svg>
    </label>

    <!-- Phone Field -->
    <label class='feedback-form__field feedback-form__field--floating-label'>
      <input class='feedback-form__input' type='tel' name='user-phone' placeholder=' ' required />
      <span class='feedback-form__label'>Phone</span>
      <svg class='feedback-form__icon' width='16px' height='16px'>
        <use href='assets/icons/sprite.svg#icon-ui-call'></use>
      </svg>
    </label>

    <!-- Email Field -->
    <label class='feedback-form__field feedback-form__field--floating-label'>
      <input class='feedback-form__input' type='email' name='user-email' placeholder=' ' required />
      <span class='feedback-form__label'>Email</span>
      <svg class='feedback-form__icon' width='16px' height='16px'>
        <use href='assets/icons/sprite.svg#icon-ui-mail'></use>
      </svg>
    </label>

    <!-- Message Field -->
    <label class='feedback-form__field feedback-form__field--stacked-label'>
      <span class='feedback-form__label'>Comment</span>
      <textarea class='feedback-form__textarea' name='user-comment' placeholder='Message'></textarea>
    </label>

    <!-- Policy Checkbox -->
    <label class='feedback-form__field feedback-form__field--inline-label'>
      <input class='feedback-form__checkbox' type='checkbox' name='user-policy' required />
      <span class='feedback-form__checkbox-custom'></span>
      <span class='feedback-form__checkbox-label'>
        I agree to the
        <a class='feedback-form__link' href=''>Privacy Policy</a>
      </span>
    </label>

    <button class='button button--primary feedback-form__submit' type='submit'>Send Message</button>
  </form>
</div>
